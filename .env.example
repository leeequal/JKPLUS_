# Environment Variables Example
# Copy this file to .env.local and fill in your actual values
# IMPORTANT: Never commit .env.local to version control!

# Google Gemini API Key
# ⚠️ SECURITY WARNING: 
# - Do NOT hardcode API keys in client-side code
# - This key should ONLY be used in a server environment
# - For production, use environment variables on the server side only
# - Client should make requests to your backend, not directly to the API
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration (for future backend)
# These are examples only - configure on the server side
VITE_API_BASE_URL=http://localhost:3000/api

# Application Mode
VITE_APP_ENV=development
